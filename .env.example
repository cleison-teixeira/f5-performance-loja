NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp test mode
# Definir como true em desenvolvimento para redirecionar todos os links para TEST_PHONE
# Deixar vazio ou false em produção
NEXT_PUBLIC_WHATSAPP_TEST_MODE=false
NEXT_PUBLIC_WHATSAPP_TEST_PHONE=

# URL principal do app (usada para redirecionamentos e links canônicos)
NEXT_PUBLIC_APP_URL=https://f5recompra.com.br

