NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp test mode
# Definir como true em desenvolvimento para redirecionar todos os links para TEST_PHONE
# Deixar vazio ou false em produção
NEXT_PUBLIC_WHATSAPP_TEST_MODE=false
NEXT_PUBLIC_WHATSAPP_TEST_PHONE=

# URL principal do app (usada para redirecionamentos e links canônicos)
NEXT_PUBLIC_APP_URL=https://app.f5recompra.com.br

# Asaas — Plataforma de cobranças
# Obter em: https://www.asaas.com/config/integrations
ASAAS_API_KEY=your-asaas-api-key
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_ENV=production
# Token para validar autenticidade dos webhooks recebidos do Asaas
ASAAS_WEBHOOK_TOKEN=your-asaas-webhook-token

